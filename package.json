{
  "name": "omni-stock-inventory-aggregator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/common",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
